# ─────────────────────────────────────────────────────────────
# Maison Saveur — Environment Configuration (example)
# Copy to .env.local and fill in values. Never commit .env.local
# ─────────────────────────────────────────────────────────────

# Database
DATABASE_PATH=./data/cakeshop.db

# Application
NEXT_PUBLIC_SITE_NAME="Maison Saveur"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth (Phase 1 uses mock values — Phase 2 will require real secrets)
AUTH_SECRET=replace-with-a-long-random-string-in-production
SESSION_COOKIE_NAME=maison_session

# Admin seed (used by db/seed.ts on first migration)
ADMIN_EMAIL=admin@maisonsaveur.local
ADMIN_PASSWORD=change-me-in-dev
